  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#5C6370",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["constant.language", "constant.numeric", "constant.character"],
      "settings": {
        "foreground": "#F78C6C"
      }
    },
    {
      "scope": ["constant.other"],
      "settings": {
        "foreground": "#F78C6C"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#82AAFF"
      }
    },
    {
      "scope": ["entity.name.type", "entity.other.inherited-class", "support.class"],
      "settings": {
        "foreground": "#FFCB6B",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#C792EA"
      }
    },
    {
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#C792EA"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "scope": ["string", "meta.embedded.assembly"],
      "settings": {
        "foreground": "#C3E88D"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#5CA7E4"
      }
    },
    {
      "scope": ["support.type", "support.class"],
      "settings": {
        "foreground": "#FFCB6B",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable", "meta.definition.variable.name", "support.variable"],
      "settings": {
        "foreground": "#80CBC4"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#FF5370",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#D9F5DD"
      }
    },
    {
      "scope": ["invalid.illegal"],
      "settings": {
        "foreground": "#ffffff",
        "background": "#FF5370"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#ffffff",
        "background": "#C792EA"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#F78C6C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#82AAFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#C3E88D"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#FF5370"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#C792EA"
      }
    },
    {
      "scope": ["markup.inline.raw"],
      "settings": {
        "foreground": "#C3E88D"
      }
    },
    {
      "scope": ["meta.selector"],
      "settings": {
        "foreground": "#C792EA"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#F07178"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#C792EA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#FFCB6B"
      }
    },
    {
      "scope": ["meta.property-name"],
      "settings": {
        "foreground": "#80CBC4"
      }
    },
    {
      "scope": ["meta.property-value"],
      "settings": {
        "foreground": "#C3E88D"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "scope": ["meta.preprocessor"],
      "settings": {
        "foreground": "#C792EA"
      }
    },
    {
      "scope": ["entity.name.function.preprocessor"],
      "settings": {
        "foreground": "#FFCB6B"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#C792EA"
      }
    },
    {
      "scope": ["source.ruby variable.other.readwrite"],
      "settings": {
        "foreground": "#FFCB6B"
      }
    },
    {
      "scope": ["source.css entity.name.tag", "source.sass entity.name.tag", "source.scss entity.name.tag", "source.less entity.name.tag", "source.stylus entity.name.tag"],
      "settings": {
        "foreground": "#F07178"
      }
    },
    {
      "scope": ["source.css support.type.property-name", "source.sass support.type.property-name", "source.scss support.type.property-name", "source.less support.type.property-name", "source.stylus support.type.property-name"],
      "settings": {
        "foreground": "#80CBC4"
      }
    },
    {
      "scope": ["source.js meta.function-call.constructor variable.type", "source.ts meta.function-call.constructor variable.type"],
      "settings": {
        "foreground": "#FFCB6B"
      }
    },
    {
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#80CBC4"
      }
    },
    {
      "scope": ["entity.name.function.decorator", "meta.decorator variable"],
      "settings": {
        "foreground": "#82AAFF"
      }
    }
  ]
}
