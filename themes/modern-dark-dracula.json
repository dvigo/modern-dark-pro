  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6272a4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["constant.language", "constant.numeric", "constant.character"],
      "settings": {
        "foreground": "#bd93f9"
      }
    },
    {
      "scope": ["constant.other"],
      "settings": {
        "foreground": "#bd93f9"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#50fa7b"
      }
    },
    {
      "scope": ["entity.name.type", "entity.other.inherited-class", "support.class"],
      "settings": {
        "foreground": "#8be9fd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "scope": ["string", "meta.embedded.assembly"],
      "settings": {
        "foreground": "#f1fa8c"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#f1fa8c"
      }
    },
    {
      "scope": ["support.type", "support.class"],
      "settings": {
        "foreground": "#8be9fd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable", "meta.definition.variable.name", "support.variable"],
      "settings": {
        "foreground": "#f8f8f2"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#bd93f9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#ffb86c",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["invalid.illegal"],
      "settings": {
        "foreground": "#ffffff",
        "background": "#ff5555"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#ffffff",
        "background": "#bd93f9"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#ffb86c",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#bd93f9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#50fa7b"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#ff5555"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#ffb86c"
      }
    },
    {
      "scope": ["markup.inline.raw"],
      "settings": {
        "foreground": "#f1fa8c"
      }
    },
    {
      "scope": ["meta.selector"],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#50fa7b",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#50fa7b"
      }
    },
    {
      "scope": ["meta.property-name"],
      "settings": {
        "foreground": "#8be9fd"
      }
    },
    {
      "scope": ["meta.property-value"],
      "settings": {
        "foreground": "#f1fa8c"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#8be9fd"
      }
    },
    {
      "scope": ["meta.preprocessor"],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "scope": ["entity.name.function.preprocessor"],
      "settings": {
        "foreground": "#ffb86c"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#bd93f9"
      }
    },
    {
      "scope": ["source.ruby variable.other.readwrite"],
      "settings": {
        "foreground": "#8be9fd"
      }
    },
    {
      "scope": ["source.css entity.name.tag", "source.sass entity.name.tag", "source.scss entity.name.tag", "source.less entity.name.tag", "source.stylus entity.name.tag"],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "scope": ["source.css support.type.property-name", "source.sass support.type.property-name", "source.scss support.type.property-name", "source.less support.type.property-name", "source.stylus support.type.property-name"],
      "settings": {
        "foreground": "#8be9fd"
      }
    },
    {
      "scope": ["source.js meta.function-call.constructor variable.type", "source.ts meta.function-call.constructor variable.type"],
      "settings": {
        "foreground": "#8be9fd"
      }
    },
    {
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#8be9fd"
      }
    },
    {
      "scope": ["entity.name.function.decorator", "meta.decorator variable"],
      "settings": {
        "foreground": "#50fa7b"
      }
    }
  ]
